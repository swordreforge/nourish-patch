EGL_LOG_LEVEL=debug
WAYLAND_DISPLAY=wayland-host
XDG_RUNTIME_DIR=/tmp
__EGL_EXTERNAL_PLATFORM_CONFIG_DIRS=/usr/share/egl/egl_external_platform.d
__GLX_VENDOR_LIBRARY_NAME=nvidia
MESA_LOADER_DRIVER_OVERRIDE=nvidia
__EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json
__EGL_EXTERNAL_PLATFORM_CONFIG_FILENAMES=/usr/share/egl/egl_external_platform.d/10_nvidia_wayland.json
GBM_BACKEND=nvidia-drm
NVD_BACKEND=direct
COMPOSITOR_RENDER_NODE=/dev/dri/renderD129
# Allow the NVIDIA GL driver to use G-Sync/VRR (M4: adaptive sync). Set to 0 to
# force fixed-refresh.
__GL_GSYNC_ALLOWED=1
__GL_VRR_ALLOWED=1
WINIT_UNIX_BACKEND=wayland
GDK_BACKEND=wayland
RUST_BACKTRACE=1
